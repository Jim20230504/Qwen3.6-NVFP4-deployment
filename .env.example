# =========================
# 对外访问端口
# =========================
# HTTP 对外端口
HOST_HTTP_PORT=8080
# Adminer 管理入口最终仍走 nginx 反代，这里保留变量主要用于扩展
ADMINER_PORT=8081
# LiteLLM UI 预留端口变量
LITELLM_UI_PORT=8082

# =========================
# Postgres 数据库配置
# =========================
POSTGRES_DB=ai_platform
POSTGRES_USER=ai_platform
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# LiteLLM 连接数据库使用的完整地址
DATABASE_URL=postgresql://ai_platform:change-me@postgres:5432/ai_platform

# =========================
# Hugging Face 相关
# =========================
# 如果完全走本地模型目录，可以留空
HF_TOKEN=
# Hugging Face 缓存目录
HF_HOME=/models/huggingface

# =========================
# LiteLLM 网关配置
# =========================
# 管理员主密钥，请改成你自己的高强度随机值
LITELLM_MASTER_KEY=sk-change-me
# 本机访问 LiteLLM 网关的地址
LITELLM_PROXY_URL=http://localhost:8080
# 默认 RPM / TPM / 并发限制
DEFAULT_RPM=30
DEFAULT_TPM=120000
DEFAULT_MAX_CONCURRENT=2

# =========================
# 模型别名
# =========================
MODEL_ALIAS_PRIMARY=coder
MODEL_ALIAS_FAST=coder-fast

# =========================
# 模型仓库 ID
# 主要用于记录来源，当前部署优先走本地模型目录
# =========================
QWEN32B_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
QWEN14B_MODEL_ID=Qwen/Qwen2.5-Coder-14B-Instruct
DEEPSEEK_MODEL_ID=casperhansen/deepseek-coder-v2-instruct-awq

# =========================
# 本地模型目录
# 这些路径是容器内路径，宿主机会把 ./data/models 挂载到 /models/local
# 所以你只需要保证宿主机目录结构是：
# data/models/qwen32b-awq
# data/models/qwen14b
# data/models/deepseek-v2-awq
# =========================
QWEN32B_MODEL_PATH=/models/local/qwen32b-awq
QWEN14B_MODEL_PATH=/models/local/qwen14b
DEEPSEEK_MODEL_PATH=/models/local/deepseek-v2-awq

# =========================
# vLLM 运行参数
# MAX_MODEL_LEN = 上下文长度上限
# MAX_NUM_SEQS = 并发序列数，越大越吃显存
# GPU_MEMORY_UTILIZATION = 显存利用比例
# =========================

# Qwen 32B 主模型32768
QWEN32B_MAX_MODEL_LEN=8192
QWEN32B_MAX_NUM_SEQS=2
QWEN32B_GPU_MEMORY_UTILIZATION=0.92

# Qwen 14B 快模型32768
QWEN14B_MAX_MODEL_LEN=8192
QWEN14B_MAX_NUM_SEQS=4
QWEN14B_GPU_MEMORY_UTILIZATION=0.50

# DeepSeek 主模型163840
DEEPSEEK_MAX_MODEL_LEN=8192
DEEPSEEK_MAX_NUM_SEQS=2
DEEPSEEK_GPU_MEMORY_UTILIZATION=0.92

# =========================
# Swap 配置
# 建议在 32GB RAM 的机器上保持开启
# =========================
ENABLE_SWAP_SETUP=true
SWAP_SIZE_GB=32
